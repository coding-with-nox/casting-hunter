{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": ["http://localhost:5173", "http://localhost:5050"],
  "UsePostgres": false,
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=castingradar.db"
  },
  "Keycloak": {
    "Enabled": false,
    "Authority": "http://localhost:8080/realms/myrealm",
    "Audience": "actoring-app",
    "RequireHttps": false
  },
  "CastingRadar": {
    "ScrapingIntervalHours": 6,
    "Telegram": {
      "BotToken": "",
      "ChatId": ""
    },
    "DefaultFilter": {
      "OnlyPaid": false,
      "Regions": ["Italy"],
      "GenderFilter": "female"
    },
    "EnabledSources": [
      "Ticonsiglio",
      "AttoriCasting",
      "iMoviez",
      "iCasting",
      "CastingEProvini",
      "Mandy",
      "Backstage"
    ]
  }
}
